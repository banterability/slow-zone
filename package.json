  "version": "4.3.0",
  "description": "A client & wrapper for CTA 'L' arrival data",
  "author": "Jeff Long",
  "license": "MIT",
  "exports": "./dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^25.0.2",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import-x": "^4.16.2",
    "prettier": "3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.0.3"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc",
